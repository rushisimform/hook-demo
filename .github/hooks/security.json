{
  "hooks": {
    "preToolUse": [
      {
        "name": "log-tool-usage",
        "run": "echo \"$(date) - Tool executed\" >> copilot-logs.txt"
      }
    ],
    "sessionStart": [
      {
        "name": "log-session-start",
        "run": "echo \"$(date) - Session started\" >> copilot-logs.txt"
      }
    ]
  }
}